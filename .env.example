# ══════════════════════════════════════════════
#  MACCHINAA-EVOLVED — Environment Variables
#  انسخ هذا الملف إلى .env وأضف قيمك الحقيقية
# ══════════════════════════════════════════════

# Django
SECRET_KEY=your-secret-key-here-change-this
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (PostgreSQL recommended for production)
DATABASE_URL=sqlite:///db.sqlite3
# DATABASE_URL=postgresql://user:password@localhost:5432/macchinaa

# Redis (for Celery)
REDIS_URL=redis://localhost:6379/0

# ── Auction APIs ──────────────────────────────

# Copart (via salvagebid.com or direct)
COPART_API_KEY=
COPART_USERNAME=
COPART_PASSWORD=

# IAAI
IAAI_API_KEY=
IAAI_USERNAME=
IAAI_PASSWORD=

# Manheim (OAuth2)
MANHEIM_CLIENT_ID=
MANHEIM_CLIENT_SECRET=
MANHEIM_SCOPE=openid profile email

# ADESA / OpenLane (Auth0)
ADESA_BEARER_TOKEN=
ADESA_AUTH0_CLIENT_ID=
ADESA_AUTH0_CLIENT_SECRET=
ADESA_DEALER_ID=
ADESA_DEALER_UUID=

# ACV Auctions
ACV_API_TOKEN=
ACV_DEALER_ID=

# BCA (no auth needed for public listings)
BCA_API_KEY=

# GSA / GovDeals
GSA_API_KEY=DEMO_KEY

# ── Currency & Exchange Rates ─────────────────
EXCHANGE_RATES_API_KEY=
# Free key from: https://exchangeratesapi.io/

# ── Notifications ─────────────────────────────
# WhatsApp (WaSender)
WASENDER_API_KEY=
WASENDER_WEBHOOK_SECRET=

# Email
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=

# ── Monitoring ────────────────────────────────
SENTRY_DSN=

# ── Celery ────────────────────────────────────
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
